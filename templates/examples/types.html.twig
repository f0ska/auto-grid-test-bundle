{% extends '@F0skaAutoGridTest/base.html.twig' %}
{% import '@F0skaAutoGridTest/components/theme_switcher.html.twig' as agt %}

{% block title %}Field Types Example - AutoGrid{% endblock %}

{% block content %}
    {{ agt.infoBlock('Demonstrated features:', [
        '<strong>Enums</strong>: Automatic ChoiceType dropdowns',
        '<strong>JSON/Objects</strong>: Formatted and truncated rendering',
        '<strong>Decimals & GUIDs</strong>: Specialized handling and formatting',
        '<strong>DateTime</strong>: Native support for all core PHP date types',
        '<strong>Booleans</strong>: Toggle UI or dropdown filters',
        'Selective grid visibility using field-level <code>#[Permission(\'grid\', allow: false)]</code>'
    ]) }}

    <div class="autogrid-demo-stack">
        <div class="autogrid-demo-item">{{ ag_render(main) }}</div>
        <div class="autogrid-demo-item">{{ ag_render(other) }}</div>
        <div class="autogrid-demo-item">{{ ag_render(dates) }}</div>
        <div class="autogrid-demo-item">{{ ag_render(array) }}</div>
    </div>
{% endblock %}
