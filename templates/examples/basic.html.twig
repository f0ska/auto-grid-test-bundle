{% extends '@F0skaAutoGridTest/base.html.twig' %}

{% block title %}Basic Example - AutoGrid{% endblock %}

{% block content %}
    <div class="alert alert-secondary border shadow-sm mb-4">
        <p class="mb-2"><strong>Demonstrated features:</strong></p>
        <ul class="mb-0">
            <li>Automatic field type detection from Doctrine metadata</li>
            <li>Automatic <strong>Filtering and Sorting</strong> for columns with database indexes</li>
            <li>Standard <strong>CRUD actions</strong> (Create, View, Edit, Delete)</li>
        </ul>
    </div>

    {{ agRender(grid) }}
{% endblock %}
