{% extends '@F0skaAutoGridTest/base.html.twig' %}
{% import '@F0skaAutoGridTest/components/theme_switcher.html.twig' as agt %}

{% block title %}Advanced Examples - AutoGrid{% endblock %}

{% block content %}
    {{ agt.infoBlock('Demonstrated features:', [
        'Secure-by-default access control (<code>DisallowActions</code>/<code>Fields</code>)',
        'Granular <strong>Permissions</strong> based on roles or context using <code>#[Permission]</code>',
        'Action visibility control with <code>#[ActionButtonDisplay]</code> (edit hidden on grid, available from view)',
        'Organized forms using <strong>Fieldsets</strong>',
        'Multi-criteria <strong>Advanced Filter</strong>',
        '<strong>Value Decoration</strong> with <code>#[ValuePrefix]</code> (Prefix on ID)',
        'Grid truncation for long text fields via <code>#[GridTruncate]</code>',
        '<strong>Responsive Column Sizing</strong> (<code>col-*</code> classes on columns)',
        'Custom field templates & Associated fields',
        'DQL hard-coded filters (<code>queryExpression</code>)',
        'Pre-filled grid state (filters/sorting) from controller',
        'Instance-specific <code>gridId</code> for context-aware logic',
        'Manual form field customization (Email/Nickname)',
        'JSON array handling with multi-select filtering'
    ]) }}

    <div class="autogrid-demo-stack">
        <div class="autogrid-demo-item">{{ ag_render(grid1) }}</div>
        <div class="autogrid-demo-item">{{ ag_render(grid2) }}</div>
    </div>
{% endblock %}
