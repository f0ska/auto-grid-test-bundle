{% extends '@F0skaAutoGridTest/base.html.twig' %}

{% block title %}Custom Forms & Filters - AutoGrid{% endblock %}

{% block content %}
    <div class="alert alert-secondary border shadow-sm mb-4">
        <p class="mb-2"><strong>Demonstrated features:</strong></p>
        <ul class="mb-0">
            <li>Replacing default forms with <strong>Custom Symfony Form Types</strong> (e.g., for image uploads). View the image in the 'View' action.</li>
            <li>Customizing individual fields with <code>#[FormType]</code> & <code>#[FormOptions]</code></li>
            <li><strong>Automatic Filter Configuration</strong>: Filters automatically inherit choice lists and form types from the main form configuration (e.g., the 'Status' filter uses the same choices as the form field).</li>
        </ul>
    </div>

    {{ agRender(grid) }}
{% endblock %}
