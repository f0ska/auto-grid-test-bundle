{% extends '@F0skaAutoGridTest/base.html.twig' %}
{% import '@F0skaAutoGridTest/components/theme_switcher.html.twig' as agt %}

{% block title %}Custom Forms & Filters - AutoGrid{% endblock %}

{% block content %}
    {{ agt.infoBlock('Demonstrated features:', [
        'Replacing default forms with <strong>Custom Symfony Form Types</strong> (e.g., for image uploads). View the image in the View action.',
        'Using <strong>Create, Edit, and View events</strong> with a custom form entity while keeping the grid example itself clean.',
        'Customizing individual fields with <code>#[FormType]</code> & <code>#[FormOptions]</code>',
        '<strong>Automatic Filter Configuration</strong>: Filters automatically inherit choice lists and form types from the main form configuration',
        'Custom global search service with <code>#[Searchable(service: ...)]</code>; prefix a term with <code>not </code> to exclude matches',
        'Base template slot injection with <code>#[Template(TemplateArea::BEFORE)]</code> and <code>#[Template(TemplateArea::AFTER)]</code>'
    ]) }}

    {{ ag_render(grid) }}
{% endblock %}
