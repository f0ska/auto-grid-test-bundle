{% extends '@F0skaAutoGridTest/base.html.twig' %}

{% block title %}Custom Forms & Filters - AutoGrid{% endblock %}

{% block content %}
    <div class="alert alert-secondary border shadow-sm mb-4">
        <p class="mb-2"><strong>Demonstrated features:</strong></p>
        <ul class="mb-0">
            <li>Replacing default forms with <strong>Custom Symfony Form Types</strong></li>
            <li>Customizing individual fields with <code>#[FormType]</code> & <code>#[FormOptions]</code></li>
            <li><strong>Smart Filter Fallback</strong>: Filters inheriting form settings automatically</li>
        </ul>
    </div>

    {{ agRender(grid) }}
{% endblock %}
