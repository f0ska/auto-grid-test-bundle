{% extends '@F0skaAutoGridTest/base.html.twig' %}
{% import '@F0skaAutoGridTest/components/theme_switcher.html.twig' as agt %}

{% block title %}Relations Example - AutoGrid{% endblock %}

{% block content %}
    {{ agt.infoBlock('Demonstrated features:', [
        'Automatic rendering and filtering for <strong>One-to-Many / Many-to-Many</strong> relations',
        '<strong>Associated Fields</strong>: Displaying properties from related entities directly',
        '<strong>Cross-Entity Permissions</strong>: Context-aware field visibility using <code>gridId</code> and <code>#[Permission]</code>',
        'Tighter relation column previews using per-field <code>#[GridTruncate]</code>'
    ]) }}

    <div class="autogrid-demo-stack">
        <div class="autogrid-demo-item">{{ ag_render(articles) }}</div>
        <div class="autogrid-demo-item">{{ ag_render(users) }}</div>
        <div class="autogrid-demo-item">{{ ag_render(tags) }}</div>
        <div class="autogrid-demo-item">{{ ag_render(comments) }}</div>
    </div>
{% endblock %}
