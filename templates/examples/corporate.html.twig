{% extends '@F0skaAutoGridTest/base.html.twig' %}

{% block content %}
    <div class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info shadow-sm mb-4">
                    <h4 class="alert-heading"><i class="bi bi-info-circle me-2"></i>Clean & Professional Example</h4>
                    <p class="mb-0">
                        This grid demonstrates how to use <strong>Attributes</strong> (<code>Label</code>,
                        <code>Position</code>, <code>ValuePrefix</code>, <code>HtmlClass</code>, <code>Title</code>)
                        to turn raw entity data into a clean, business-ready dashboard with zero template code.
                    </p>
                </div>

                <div class="card shadow">
                    <div class="card-body">
                        {{ agRender(grid) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
