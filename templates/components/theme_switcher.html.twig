{% macro infoBlock(title, features) %}
{% set config = agt_theme_config() %}
{% set wrapperClass = config.infoBlock.wrapper|default('alert alert-secondary border shadow-sm mb-4') %}
{% set titleClass = config.infoBlock.title|default('strong mb-2') %}
{% set rowClass = config.infoBlock.rowClass|default('row') %}
{% set colClass = config.infoBlock.colClass|default('col-md-' ~ (12 / 2)) %}
<div class="autogrid-info-block {{ wrapperClass }}">
    {% if title %}
        <p class="{{ titleClass }}">{{ title }}</p>
    {% endif %}
    {% if features %}
        {% set itemCount = features|length %}
        {% set cols = itemCount > 3 ? 2 : 1 %}
        {% set perCol = (itemCount / cols)|round(0, 'ceil') %}
        {% if cols > 1 %}
        <div class="{{ rowClass }}">
            {% for i in 0..(cols - 1) %}
                <div class="{{ colClass }}">
                    <ul class="{{ config.infoBlock.list|default('mb-0') }}">
                        {% for j in 0..(perCol - 1) %}
                            {% set idx = (i * perCol) + j %}
                            {% if idx < itemCount %}
                                {% set feature = features[idx] %}
                                {% if feature is iterable %}
                                    <li>{{ feature[0]|raw }}</li>
                                {% else %}
                                    <li>{{ feature|raw }}</li>
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}
        </div>
        {% else %}
        <ul class="{{ config.infoBlock.list|default('mb-0') }}">
            {% for feature in features %}
                {% if feature is iterable %}
                    <li>{{ feature[0]|raw }}</li>
                {% else %}
                    <li>{{ feature|raw }}</li>
                {% endif %}
            {% endfor %}
        </ul>
        {% endif %}
    {% endif %}
</div>
{% endmacro %}

{% macro themeSwitcher() %}
{% set themes = agt_theme_list() %}
{% set currentTheme = agt_current_theme() %}

<div class="autogrid-theme-switcher">
    <div class="autogrid-theme-switcher-inner">
        {% for key, theme in themes %}
            {% set url = agt_theme_url(key) %}
            {% set isActive = currentTheme == key %}
            <a href="{{ url }}"
               class="autogrid-theme-btn {{ isActive ? 'active' }}"
               title="{{ theme.label }}"
               data-theme="{{ key }}"
               data-turbo="false"
            >
                {{ _self.themeIcon(theme.icon) }}
                <span class="autogrid-theme-label">{{ theme.label }}</span>
            </a>
        {% endfor %}
    </div>
</div>
{% endmacro %}
