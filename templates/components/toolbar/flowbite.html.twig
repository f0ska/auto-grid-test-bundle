{% import '@F0skaAutoGridTest/components/theme_switcher.html.twig' as agt %}

<nav class="bg-gray-900 text-white fixed w-full top-0 z-50">
    <div class="max-w-screen-2xl mx-auto px-4">
        <div class="flex items-center justify-center h-14">
            <div class="hidden md:flex md:space-x-2">
                {% for item in navItems %}
                    <a class="block py-1.5 px-2.5 rounded-md font-medium transition-colors {{ agt_is_nav_active(item.route) ? 'bg-gray-800 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}"
                       style="font-size: 0.94rem;"
                   href="{{ agt_theme_url(null, item.route) }}">
                    {{ item.label }}
                </a>
            {% endfor %}
        </div>
        <div class="md:hidden hidden" id="mobile-menu">
            {% for item in navItems %}
                <a class="block py-2 px-4 text-sm text-gray-300 hover:bg-gray-800 hover:text-white"
                   href="{{ agt_theme_url(null, item.route) }}">
                    {{ item.label }}
                </a>
            {% endfor %}
        </div>
    </div>
</nav>
<style>
    .autogrid-theme-btn svg {
        width: 24px !important;
        height: 24px !important;
    }
    body {
        padding-top: 56px !important;
    }
</style>
