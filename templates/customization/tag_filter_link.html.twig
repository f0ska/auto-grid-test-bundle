{% if (value is empty) %}
    -
{% else %}
    {% set currentTheme = agt_current_theme()|default('auto-grid') %}
    {% set isBootstrap4 = currentTheme == 'auto-grid-bootstrap4' or app.request.pathinfo starts with '/auto-grid-bootstrap4/' %}
    {% set containerClass = 'd-flex flex-wrap gap-1' %}
    {% set badgeClass = 'badge bg-secondary text-decoration-none' %}

    {% if isBootstrap4 %}
        {% set containerClass = 'd-flex flex-wrap align-items-center' %}
        {% set badgeClass = 'badge badge-info text-white text-decoration-none mr-1 mb-1 px-2 py-1' %}
    {% elseif currentTheme == 'auto-grid-bulma' %}
        {% set containerClass = 'tags' %}
        {% set badgeClass = 'tag is-info' %}
    {% elseif currentTheme == 'auto-grid-foundation' %}
        {% set containerClass = 'flex-container button-group tiny' %}
        {% set badgeClass = 'button secondary tiny' %}
    {% elseif currentTheme == 'auto-grid-flowbite' %}
        {% set containerClass = 'flex flex-wrap gap-1' %}
        {% set badgeClass = 'bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-gray-700 dark:text-gray-300' %}
    {% endif %}

    <div class="{{ containerClass }}">
        {% for key, id in values %}
            {% set label = attribute(labels, key) %}
            <a href="{{ ag_run(agActionUrl, 'grid', {'filter': {'tags': id}}) }}" class="{{ badgeClass }}">
                {{ label }}
            </a>
        {% endfor %}
    </div>
{% endif %}
